{
  "name": "universal-sql-prettier",
  "displayName": "Universal SQL Prettier",
  "description": "Format SQL queries inside any programming language file",
  "version": "0.0.6",
  "publisher": "sagarDev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "images/image.png",
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "sql",
    "formatter",
    "database",
    "prettier",
    "query",
    "mysql",
    "postgres"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sagarr-singh/vs_code_universal_sql_formatter_ext.git"
  },
  "homepage": "https://github.com/sagarr-singh/vs_code_universal_sql_formatter_ext",
  "bugs": {
    "url": "https://github.com/sagarr-singh/vs_code_universal_sql_formatter_ext/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sql"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sqlFormatter.formatQuery",
        "title": "Format SQL Query"
      }
    ],
    "keybindings": [
      {
        "command": "sqlFormatter.formatQuery",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus"
      }
    ],
    "languages": [
      {
        "id": "sql",
        "aliases": [
          "SQL"
        ],
        "extensions": [
          ".sql"
        ]
      }
    ],
    "documentFormattingEditProvider": true,
    "configuration": {
      "title": "Universal SQL Prettier",
      "properties": {
        "sqlFormatter.dialect": {
          "type": "string",
          "default": "postgresql",
          "enum": [
            "mysql",
            "postgresql",
            "sqlite",
            "tsql"
          ],
          "description": "SQL dialect used for formatting"
        }
      },
      "sqlFormatter.formatOnSave": {
        "SqlFormatter.formatOnSave": "true",
        "type": "boolean",
        "default": false,
        "description": "Automatically format SQL when saving file"
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "sqlFormatter.formatQuery",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "sql-formatter": "^15.7.2"
  }
}
